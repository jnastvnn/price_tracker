# Ignore everything by default
*

# Keep this file tracked
!.gitignore
!docker-compose.yml

# Explicitly ignore non-app directories
scripts/
other\ scripts/
database/
RAG/
chroma_rag_db/

# Track only app folders
!client/
!client/**
!server/
!server/**

# Ignore generated or sensitive files inside tracked folders
client/node_modules/
client/dist/
client/dist-ssr/
client/.vite/
client/.eslintcache
client/.env
client/.env.*

server/node_modules/
server/dist/
server/build/
server/.env
server/.env.*

# OS/editor noise inside tracked folders
**/.DS_Store
**/.idea/
**/.vscode/
**/*.swp
**/*.swo
